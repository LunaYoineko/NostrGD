# Godot 4+ specific ignores
.godot/
/android/
build/

# Auto-generated UID files (regenerated by Godot on project open)
*.uid

# Keystores (sensitive signing keys)
*.keystore

# GDExtension build artifacts
addons/nostr_godot/gdextension/build/
addons/nostr_godot/gdextension/libsecp256k1/
addons/nostr_godot/gdextension/godot-cpp/*/
addons/nostr_godot/gdextension/godot-cpp/*.py
addons/nostr_godot/gdextension/godot-cpp/*.cfg
addons/nostr_godot/gdextension/extension_api.json
addons/nostr_godot/gdextension/gdextension_interface.h
addons/nostr_godot/gdextension/lib/*.so
addons/nostr_godot/gdextension/lib/*.dll
addons/nostr_godot/gdextension/lib/*.dylib
addons/nostr_godot/gdextension/lib/*.wasm

fonts/
icons/
